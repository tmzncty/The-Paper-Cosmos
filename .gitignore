# 《纸上宇宙》.gitignore

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# Node (if any tooling)
node_modules/

# Temp
*.tmp
*.bak
*.log

# Large files (track separately)
*.pdf
*.docx
*.xlsx
*.doc
*.pptx

# 研考素材 — 本地分析用，不上传
研考素材/

# Build artifacts & archived temp files
_archive/
drafts/_archive/
key.pem
